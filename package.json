{
  "name": "nomadexapp",
  "version": "0.2.10",
  "description": "Remote browser workspace for local coding agents",
  "license": "MIT",
  "type": "module",
  "bin": "./bin/nomadex.mjs",
  "files": [
    "bin",
    "dist",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "codex",
    "agents",
    "remote",
    "mobile",
    "workspace",
    "cli"
  ],
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xaenic/nomadex.git"
  },
  "homepage": "https://github.com/xaenic/nomadex",
  "bugs": {
    "url": "https://github.com/xaenic/nomadex/issues"
  },
  "scripts": {
    "start": "node ./bin/nomadex.mjs",
    "dev": "vite",
    "app-server": "codex app-server --listen ws://127.0.0.1:3901",
    "dev:live": "node ./scripts/dev-live.mjs",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@openai/codex": "^0.116.0",
    "@codemirror/language": "^6.12.2",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.40.0",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/sora": "^5.2.8",
    "@tanstack/react-query": "^5.91.2",
    "@tanstack/react-router": "^1.167.5",
    "@tanstack/react-virtual": "^3.13.23",
    "@uiw/react-codemirror": "^4.25.8",
    "clsx": "^2.1.1",
    "http-proxy": "^1.18.1",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1"
  }
}
